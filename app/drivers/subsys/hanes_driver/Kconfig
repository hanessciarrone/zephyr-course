menuconfig HANES_DRIVER
    bool "Enable Hanes LED sensor driver"
    depends on DT_HAS_HANES_DRIVER_ENABLED
    select GPIO
    select SENSOR
    help
        Enable the simple GPIO-backed LED sensor driver used to toggle LD2.

    if HANES_DRIVER
        config HANES_DRIVER_MESSAGE_MAX_LEN
            int "Maximum message length"
            default 64
            help
                Maximum message length (Please note it is the length of an array of char)
    endif # HANES_DRIVER
